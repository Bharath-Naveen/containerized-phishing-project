# Copy to ".env" for docker compose / local runs (never commit .env).

# Optional: OpenAI for legacy AI brand/task stage in app_v1 (not required for Layer-1 ML).
OPENAI_API_KEY=

# Optional: Kaggle API (only if using kagglehub download).
# Prefer placing Kaggle credentials in ~/.kaggle/kaggle.json (also gitignored globally).
KAGGLE_USERNAME=
KAGGLE_KEY=

# Project paths (defaults work inside Docker; override on host if needed)
# PHISH_PROJECT_ROOT=
# PHISH_DATA_DIR=
# PHISH_OUTPUTS_DIR=
# PHISH_LOGS_DIR=
# PHISH_OUTPUT_DIR=

# Capture / browser tuning (see src/app_v1/config.py)
# PHISH_NAV_TIMEOUT_MS=25000
# PHISH_WAIT_UNTIL=domcontentloaded
